{
  "name": "nodoc",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "npm run generate:site-data && docusaurus start",
    "build": "npm run generate:site-data && docusaurus build",
    "capture:deep-crawl": "node tools/cdp-deep-capture.mjs",
    "generate:crawl-baseline": "node tools/generate-portal-crawl-baseline.mjs",
    "generate:crawl-candidates": "node tools/generate-crawl-candidates.mjs",
    "generate:recipe-audit": "node tools/generate-recipe-audit.mjs",
    "generate:coverage-ledger": "node tools/generate-portal-coverage-ledger.mjs",
    "generate:postman": "node tools/generate-postman-collections.mjs",
    "generate:site-data": "node tools/generate-spec-quality.mjs && node tools/generate-portal-coverage-ledger.mjs && node tools/generate-operation-live-capture-ledger.mjs && node tools/generate-operation-context-ledger.mjs",
    "validate:portal-discovery": "node tools/validate-portal-discovery-metadata.mjs",
    "validate:site-data": "npm run generate:site-data && git diff --exit-code -- src/generated/specQuality.ts src/generated/portalCoverageLedger.json src/generated/operationLiveCaptureLedger.json src/generated/operationContextLedger.json",
    "validate:spec-quality": "node tools/validate-spec-quality.mjs",
    "swizzle": "docusaurus swizzle",
    "deploy": "npm run build && wrangler deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "npm run generate:site-data && tsc",
    "preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@iconify/react": "^6.0.2",
    "@mdx-js/react": "^3.0.0",
    "@scalar/api-reference-react": "^0.9.24",
    "@scalar/openapi-parser": "^0.25.10",
    "clsx": "^2.0.0",
    "fast-glob": "^3.3.0",
    "lodash": "^4.18.1",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/tsconfig": "^3.10.0",
    "@docusaurus/types": "^3.10.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.79.0"
  },
  "overrides": {
    "dompurify": "3.4.0",
    "serialize-javascript": "7.0.5",
    "postcss-calc": "10.1.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=22.0"
  }
}
