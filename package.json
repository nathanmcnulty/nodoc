{
  "name": "nodoc",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "npm run generate:site-data && docusaurus start",
    "build": "npm run generate:site-data && docusaurus build",
    "generate:postman": "node tools/generate-postman-collections.mjs",
    "generate:site-data": "node tools/generate-spec-quality.mjs",
    "validate:spec-quality": "node tools/validate-spec-quality.mjs",
    "swizzle": "docusaurus swizzle",
    "deploy": "npm run build && wrangler deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "npm run generate:site-data && tsc",
    "preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@iconify/react": "^6.0.2",
    "@mdx-js/react": "^3.0.0",
    "@scalar/api-reference-react": "^0.9.18",
    "@scalar/openapi-parser": "^0.25.7",
    "clsx": "^2.0.0",
    "fast-glob": "^3.3.0",
    "lodash": "^4.18.1",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.79.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=22.0"
  }
}
