    "wait-ms=8000",
    "capture=users",
    "click-contains-root=Groups",
    "wait-ms=8000",
    "capture=groups",
    "click-contains-root=Billing",
    "wait-ms=8000",
    "capture=billing",
    "click-contains-root=Settings",
    "wait-ms=8000",
    "capture=settings",
    "click-contains-root=Copilot",
    "wait-ms=8000",
    "capture=copilot",
