{
  "portal": "M365 Apps",
  "url": "https://config.office.com/officeSettings",
  "matchHosts": [
    "config.office.com",
    "clients.config.office.net",
    "query.inventory.insights.office.net"
  ],
  "postActionSettleMs": 10000,
  "settleMs": 12000,
  "actions": [
    "click-contains-root=Inventory",
    "wait-ms=6000",
    "capture=inventory",
    "click-contains-root=Health",
    "wait-ms=6000",
    "capture=health",
    "click-contains-root=Cloud Update",
    "wait-ms=6000",
    "capture=cloud-update",
    "click-contains-root=Customization",
    "wait-ms=6000",
    "capture=customization",
    "click-contains-root=Setup"
    ,"wait-ms=6000"
    ,"capture=setup"
  ]
}
