{
  "portal": "Purview",
  "url": "https://purview.microsoft.com",
  "matchHosts": [
    "purview.microsoft.com"
  ],
  "matchPathPrefixes": [
    "/apiproxy"
  ],
  "postActionSettleMs": 12000,
  "settleMs": 14000,
  "actions": [
    "click-contains-root=eDiscovery",
    "wait-ms=8000",
    "capture=ediscovery",
    "click-contains-root=Data Loss Prevention",
    "wait-ms=8000",
    "capture=data-loss-prevention",
    "click-contains-root=Records Management",
    "wait-ms=8000",
    "capture=records-management",
    "click-contains-root=Insider Risk",
    "wait-ms=8000",
    "capture=insider-risk",
    "click-contains-root=Compliance Manager",
    "wait-ms=8000",
    "capture=compliance-manager",
    "click-contains-root=Audit",
    "wait-ms=8000",
    "capture=audit",
    "click-contains-root=Purview for AI",
    "wait-ms=8000",
    "capture=purview-for-ai"
  ]
}