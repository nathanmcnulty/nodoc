{
  "portal": "Intune Portal",
  "url": "https://intune.microsoft.com",
  "matchHosts": [
    "intune.microsoft.com"
  ],
  "matchPathPrefixes": [
    "/api"
  ],
  "postActionSettleMs": 12000,
  "settleMs": 14000,
  "actions": [
    "click-label-root=Tenant administration",
    "wait-ms=8000",
    "capture=tenant-administration",
    "click-contains-root=Multi Admin Approval",
    "wait-ms=8000",
    "capture=multi-admin-approval",
    "click-contains-root=Diagnostics settings",
    "wait-ms=8000",
    "capture=diagnostics-settings",
    "click-contains-root=Terms and conditions",
    "wait-ms=8000",
    "capture=terms-and-conditions",
    "click-label-root=Devices",
    "wait-ms=8000",
    "capture=devices",
    "click-label-root=Apps",
    "wait-ms=8000",
    "capture=apps",
    "click-label-root=Endpoint security",
    "wait-ms=8000",
    "capture=endpoint-security"
  ]
}