{
  "portal": "M365 Apps Config",
  "url": "https://config.office.com/officeSettings",
  "matchHosts": [
    "config.office.com"
  ],
  "matchPathPrefixes": [
    "/appConfig",
    "/endpointprovisionhealth",
    "/intents",
    "/policyadmin",
    "/releases",
    "/rollout",
    "/serviceProfile",
    "/ServiceProfile",
    "/settings"
  ],
  "postActionSettleMs": 10000,
  "settleMs": 12000,
  "actions": [
    "navigate=https://config.office.com/officeSettings/customization",
    "wait-ms=6000",
    "capture=customization",
    "navigate=https://config.office.com/officeSettings/policy",
    "wait-ms=6000",
    "capture=policies",
    "navigate=https://config.office.com/officeSettings/cloudUpdate",
    "wait-ms=6000",
    "capture=cloud-update",
    "navigate=https://config.office.com/officeSettings/serviceProfile",
    "wait-ms=6000",
    "capture=servicing-profiles",
    "navigate=https://config.office.com/officeSettings/deviceConfiguration",
    "wait-ms=6000",
    "capture=device-configuration",
    "navigate=https://config.office.com/officeSettings/setup",
    "wait-ms=6000",
    "capture=setup"
  ]
}