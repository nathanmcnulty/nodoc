{
  "portal": "SharePoint",
  "url": "https://${tenant}-admin.sharepoint.com/",
  "matchHosts": [
    "${tenant}-admin.sharepoint.com"
  ],
  "matchPathPrefixes": [
    "/_api"
  ],
  "postActionSettleMs": 10000,
  "settleMs": 12000,
  "actions": [
    "click-contains-root=Sites",
    "wait-ms=6000",
    "capture=sites",
    "click-contains-root=Active sites",
    "wait-ms=6000",
    "capture=active-sites",
    "click-label-root=Deleted sites",
    "wait-ms=6000",
    "capture=deleted-sites",
    "click-label-root=Migration",
    "wait-ms=6000",
    "capture=migration",
    "click-contains-root=Policies",
    "wait-ms=6000",
    "capture=policies",
    "click-contains-root=Reports",
    "wait-ms=6000",
    "capture=reports",
    "click-contains-root=Settings",
    "wait-ms=6000",
    "capture=settings",
    "click-contains-root=Advanced management",
    "wait-ms=6000",
    "capture=advanced-management",
    "click-label-root=Service health",
    "wait-ms=6000",
    "capture=service-health",
    "click-label-root=View report",
    "wait-ms=6000",
    "capture=view-report"
  ]
}
