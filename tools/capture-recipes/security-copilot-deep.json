{
  "portal": "Security Copilot",
  "url": "https://securitycopilot.microsoft.com",
  "matchHosts": [
    "securitycopilot.microsoft.com",
    "api.securitycopilot.microsoft.com",
    "api.securityplatform.microsoft.com",
    "us.api.securityplatform.microsoft.com",
    "prod.cds.securitycopilot.microsoft.com",
    "securitymarketplaceapi-prod.microsoft.com",
    "ecs.office.com"
  ],
  "matchPathPrefixes": [
    "/auth",
    "/users",
    "/settings",
    "/userPreferences",
    "/usage",
    "/graphData",
    "/provisioning",
    "/account",
    "/api/gateway",
    "/pods",
    "/trial",
    "/catalog",
    "/config/v1/SecurityMarketplaceClient"
  ],
  "settleMs": 12000,
  "postActionSettleMs": 10000,
  "actions": [
    "click-label-root=Cancel",
    "click-label-root=Agents",
    "wait-ms=10000",
    "capture=agents",
    "click-label-root=Promptbooks",
    "wait-ms=10000",
    "capture=promptbooks",
    "click-label-root=Manage workspaces",
    "wait-ms=10000",
    "capture=manage-workspaces",
    "click-label-root=Usage monitoring",
    "wait-ms=10000",
    "capture=usage-monitoring",
    "click-label-root=Security Store",
    "wait-ms=10000",
    "capture=security-store",
    "click-label-root=BuildPreview",
    "wait-ms=10000",
    "capture=build",
    "click-label-root=Get started",
    "wait-ms=6000",
    "capture=builder"
  ]
}
