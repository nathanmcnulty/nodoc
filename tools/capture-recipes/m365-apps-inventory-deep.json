{
  "portal": "M365 Apps Inventory",
  "url": "https://config.office.com/officeSettings",
  "matchHosts": [
    "config.office.com",
    "query.inventory.insights.office.net"
  ],
  "matchPathPrefixes": [
    "/inventory"
  ],
  "postActionSettleMs": 10000,
  "settleMs": 12000,
  "actions": [
    "navigate=https://config.office.com/officeSettings/inventory",
    "wait-ms=6000",
    "capture=inventory",
    "navigate=https://config.office.com/officeSettings/securityUpdate",
    "wait-ms=6000",
    "capture=security-update-status",
    "navigate=https://config.office.com/officeSettings/health",
    "wait-ms=6000",
    "capture=health",
    "navigate=https://config.office.com/officeSettings/setup",
    "wait-ms=6000",
    "capture=setup"
  ]
}