    "capture=windows-quality-updates",
    "click-contains-root=Windows feature updates",
    "wait-ms=8000",
    "capture=windows-feature-updates",
    "click-contains-root=Autopatch groups",
    "wait-ms=8000",
    "capture=autopatch-groups",
    "click-contains-root=Roles",
    "wait-ms=8000",
