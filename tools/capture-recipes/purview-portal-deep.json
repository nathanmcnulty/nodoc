{
  "portal": "Purview Portal",
  "url": "https://purview.microsoft.com",
  "matchHosts": [
    "purview.microsoft.com"
  ],
  "matchPathPrefixes": [
    "/api"
  ],
  "postActionSettleMs": 10000,
  "settleMs": 12000,
  "actions": [
    "click-label-root=Compliance Manager",
    "wait-ms=6000",
    "capture=compliance-manager",
    "click-label-root=View details in Compliance Manager",
    "wait-ms=6000",
    "capture=compliance-manager-detail",
    "click-label-root=Data Catalog",
    "wait-ms=6000",
    "capture=data-catalog",
    "click-label-root=Data Loss Prevention",
    "wait-ms=6000",
    "capture=data-loss-prevention",
    "click-contains-root=eDiscovery",
    "wait-ms=6000",
    "capture=ediscovery",
    "click-contains-root=Records Management",
    "wait-ms=6000",
    "capture=records-management",
    "click-label-root=Information Protection",
    "wait-ms=6000",
    "capture=information-protection",
    "click-contains-root=Audit",
    "wait-ms=6000",
    "capture=audit",
    "click-contains-root=Settings",
    "wait-ms=6000",
    "capture=settings",
    "click-contains-root=OCR",
    "wait-ms=6000",
    "capture=ocr-settings",
    "click-label-root=Usage center (preview)",
    "wait-ms=6000",
    "capture=usage-center"
  ]
}
