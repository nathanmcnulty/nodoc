{
  "portal": "SharePoint",
  "url": "https://${tenant}-admin.sharepoint.com/",
  "matchHosts": [
    "${tenant}-admin.sharepoint.com"
  ],
  "matchPathPrefixes": [
    "/_api"
  ],
  "seedLinkLimit": 2,
  "actions": [
    "replay-seeded-links=sites",
    "replay-seeded-links=active-sites",
    "replay-seeded-links=deleted-sites",
    "replay-seeded-links=migration",
    "replay-seeded-links=policies",
    "replay-seeded-links=reports",
    "replay-seeded-links=settings",
    "replay-seeded-links=advanced-management",
    "replay-seeded-links=service-health",
    "replay-seeded-links=view-report"
  ]
}