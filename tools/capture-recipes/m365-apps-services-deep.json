{
  "portal": "M365 Apps Services",
  "url": "https://config.office.com/officeSettings",
  "matchHosts": [
    "config.office.com",
    "clients.config.office.net"
  ],
  "matchPathPrefixes": [
    "/intents",
    "/odbhealth",
    "/onboarding",
    "/releases"
  ],
  "postActionSettleMs": 10000,
  "settleMs": 12000,
  "actions": [
    "navigate=https://config.office.com/officeSettings/health",
    "wait-ms=6000",
    "capture=health",
    "navigate=https://config.office.com/officeSettings/oneDrive",
    "wait-ms=6000",
    "capture=onedrive-sync",
    "navigate=https://config.office.com/officeSettings/cloudUpdate",
    "wait-ms=6000",
    "capture=cloud-update",
    "navigate=https://config.office.com/officeSettings/customization",
    "wait-ms=6000",
    "capture=customization",
    "navigate=https://config.office.com/officeSettings/setup",
    "wait-ms=6000",
    "capture=setup"
  ]
}