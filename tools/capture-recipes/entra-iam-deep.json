{
  "portal": "Entra IAM",
  "url": "https://entra.microsoft.com",
  "matchHosts": [
    "entra.microsoft.com",
    "main.iam.ad.ext.azure.com"
  ],
  "postActionSettleMs": 12000,
  "settleMs": 14000,
  "actions": [
    "click-contains-root=Users",
    "wait-ms=8000",
    "capture=users",
    "click-contains-root=Groups",
    "wait-ms=8000",
    "capture=groups",
    "click-contains-root=Applications",
    "wait-ms=8000",
    "capture=applications",
    "click-contains-root=Enterprise applications",
    "wait-ms=8000",
    "capture=enterprise-applications",
    "click-contains-root=Authentication methods",
    "wait-ms=8000",
    "capture=authentication-methods",
    "click-contains-root=Devices",
    "wait-ms=8000",
    "capture=devices",
    "click-contains-root=Conditional Access",
    "wait-ms=8000",
    "capture=conditional-access",
    "click-contains-root=Audit logs",
    "wait-ms=8000",
    "capture=audit-logs",
    "click-contains-iframe=Users",
    "wait-ms=6000",
    "capture=users-iframe",
    "click-contains-iframe=Groups",
    "wait-ms=6000",
    "capture=groups-iframe"
  ]
}