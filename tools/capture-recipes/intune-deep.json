{
  "portal": "Intune",
  "url": "https://intune.microsoft.com",
  "matchHosts": [
    "intune.microsoft.com",
    "services.autopatch.microsoft.com"
  ],
  "postActionSettleMs": 10000,
  "settleMs": 12000,
  "actions": [
    "click-label-root=Update Windows from the cloud",
    "wait-ms=6000",
    "capture=update-windows-from-the-cloud",
    "click-label-root=Reports",
    "wait-ms=6000",
    "capture=reports",
    "click-label-root=Devices",
    "wait-ms=6000",
    "capture=devices",
    "click-label-root=Apps",
    "wait-ms=6000",
    "capture=apps",
    "click-label-root=Tenant administration",
    "wait-ms=6000",
    "capture=tenant-administration",
    "click-label-root=Endpoint security"
    ,"wait-ms=6000"
    ,"capture=endpoint-security"
  ]
}
